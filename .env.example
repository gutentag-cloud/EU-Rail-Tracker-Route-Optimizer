```env
# ── Database (optional — falls back to in-memory) ────
DATABASE_URL=postgresql+asyncpg://rail:rail@localhost:5432/railtracker

# ── Redis (optional — falls back to no-cache) ────────
REDIS_URL=redis://localhost:6379/0

# ── App ──────────────────────────────────────────────
DEFAULT_OPERATOR=db
LOG_LEVEL=info

# ── Cache TTLs (seconds) ─────────────────────────────
CACHE_TTL_DEPARTURES=30
CACHE_TTL_STATIONS=3600
CACHE_TTL_TRIPS=300
CACHE_TTL_GEOMETRY=86400

# ── WebSocket ────────────────────────────────────────
WS_BROADCAST_INTERVAL=15

# ── Overpass ─────────────────────────────────────────
OVERPASS_RATE_LIMIT=2

# ── Delay Tracker ───────────────────────────────────
DELAY_RETENTION_HOURS=24
